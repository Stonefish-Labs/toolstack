# /home/admin/.config/toolstack/broker.env
# Loaded by docs/deployment/systemd/broker.service via EnvironmentFile=.

BROKER_BIND_ADDR=127.0.0.1:8765
BROKER_STATE_DIR=/home/admin/.local/state/toolstack/broker
BROKER_TOOLS_DIR=/home/admin/.local/share/toolstack/tools

BROKER_APPROVAL_TIMEOUT_SECONDS=86400
BROKER_GRANT_DEFAULT_TTL_SECONDS=3600

BROKER_DEFAULT_DISPATCHER=routing
BROKER_DISPATCH_TIMEOUT_SECONDS=30.0
BROKER_DISPATCH_HOST=127.0.0.1

BROKER_PUBLIC_URL=https://broker.your-tailnet.ts.net
BROKER_ALLOW_UNKNOWN_TOOLS=false

BROKER_APPROVER_SIGNING_SECRET_FILE=/home/admin/.config/toolstack/tokens/broker-approver-signing.key

# /home/admin/.config/toolstack/toolyard.env
# Loaded by docs/deployment/systemd/toolyardd.service via EnvironmentFile=.

TOOLYARD_INFISICAL_HOST=https://infisical.internal.example:19081
TOOLYARD_INFISICAL_ENVIRONMENT=prod
TOOLYARD_INFISICAL_CREDENTIALS_DIR=/home/admin/.config/toolstack/infisical
# TOOLYARD_INFISICAL_ORGANIZATION_SLUG=

TOOLYARD_TOOLS_DIR=/home/admin/.local/share/toolstack/tools
TOOLYARD_STATE_DIR=/home/admin/.local/state/toolstack
TOOLYARD_RUNTIME_DIR=/run/toolstack/toolyardd
TOOLYARD_CONTROL_SOCKET=/run/toolstack/toolyardd/control.sock
TOOLYARD_USER_UID=10000

TOOLYARD_BROKER_RELOAD_URL=http://127.0.0.1:8765/v1/registry/reload
TOOLYARD_BROKER_RELOAD_TOKEN_FILE=/home/admin/.config/toolstack/tokens/broker-registry-admin.token

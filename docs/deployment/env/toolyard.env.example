# /home/admin/.config/toolstack/toolyard.env
# Loaded by docs/deployment/systemd/toolyardd.service via EnvironmentFile=.

TOOLYARD_OP_CONNECT_HOST=http://CONNECT-HOST:19080
TOOLYARD_OP_CONNECT_TOKEN_FILE=/home/admin/.config/toolstack/tokens/op-connect-read.token
TOOLYARD_OP_CONNECT_WRITE_TOKEN_FILE=/home/admin/.config/toolstack/tokens/op-connect-readwrite.token

TOOLYARD_TOOLS_DIR=/home/admin/toolstack/tools
TOOLYARD_STATE_DIR=/home/admin/toolstack/toolyard/state
TOOLYARD_RUNTIME_DIR=/run/toolstack/toolyardd
TOOLYARD_USER_UID=10000

TOOLYARD_BROKER_RELOAD_URL=http://127.0.0.1:8765/v1/registry/reload
TOOLYARD_BROKER_RELOAD_TOKEN_FILE=/home/admin/.config/toolstack/tokens/broker-registry-admin.token

# Copy to ~/.config/op-connect-shim.env and chmod 600.
# Do not commit real token values.

OP_CONNECT_HOST=http://connect.your-tailnet.ts.net:19080

# Prefer a token file for services.
OP_CONNECT_TOKEN_FILE=/run/secrets/op-connect-token

# Or, for local-only experiments:
# OP_CONNECT_TOKEN=replace-me
